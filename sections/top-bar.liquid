{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign social_icons = true
  if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
    assign social_icons = false
  endif
-%}

{%- style -%}
  .top-bar-wrapper {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: 0.8rem 0;
    font-size: 1.2rem;
  }
  .top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-height: 3.5rem;
  }
  .top-bar__left, .top-bar__right {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex: 1;
  }
  .top-bar__right {
    justify-content: flex-end;
  }
  .top-bar__center {
    flex: 2;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .top-bar .announcement-bar-slider {
    width: 100%;
    max-width: 50rem;
  }
  .top-bar .announcement-bar__message {
    color: {{ section.settings.text_color }} !important;
    font-family: var(--font-heading-family);
    font-weight: 500;
    font-size: 1.3rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0;
    text-align: center !important;
    width: 100%;
  }
  .top-bar .announcement-bar__message span {
    color: {{ section.settings.text_color }} !important;
  }
  .top-bar .announcement-bar__message a {
    color: {{ section.settings.text_color }} !important;
    text-decoration: underline;
  }
  .top-bar .slider-button {
    color: {{ section.settings.text_color }} !important;
  }
  .top-bar .list-social__link {
    color: {{ section.settings.text_color }} !important;
  }
  .top-bar .localization-form {
    padding: 0;
    margin: 0;
  }
  .top-bar .localization-selector.link {
    color: {{ section.settings.text_color }} !important;
    font-size: 1.2rem;
    text-decoration: none;
  }
  .top-bar svg {
    fill: {{ section.settings.text_color }} !important;
    color: {{ section.settings.text_color }} !important;
  }
  /* Keep text centered on every device level */
  .top-bar .announcement-bar__announcement {
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    text-align: center !important;
    width: 100% !important;
  }
  @media screen and (max-width: 989px) {
    .top-bar__left, .top-bar__right {
      display: none !important;
    }
    .top-bar__center {
      flex: 1;
    }
  }
{%- endstyle -%}

<div class="top-bar-wrapper">
  <div class="page-width top-bar">
    <div class="top-bar__left">
      {%- if section.settings.show_social and social_icons -%}
        {%- render 'social-icons' -%}
      {%- endif -%}
    </div>
    
    <div class="top-bar__center">
      {%- if section.blocks.size == 1 -%}
        <div class="announcement-bar" role="region" aria-label="Announcement" {{ section.blocks.first.shopify_attributes }}>
          {%- if section.blocks.first.settings.text != blank -%}
            {%- if section.blocks.first.settings.link != blank -%}
              <a href="{{ section.blocks.first.settings.link }}" class="announcement-bar__link link link--text focus-inset">
            {%- endif -%}
            <p class="announcement-bar__message">
              <span>{{ section.blocks.first.settings.text | escape }}</span>
            </p>
            {%- if section.blocks.first.settings.link != blank -%}
              </a>
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- elsif section.blocks.size > 1 -%}
        <slideshow-component
          class="announcement-bar"
          role="region"
          aria-roledescription="Carousel"
          aria-label="Announcements"
        >
          <div class="announcement-bar-slider slider-buttons">
            <button
              type="button"
              class="slider-button slider-button--prev"
              name="previous"
              aria-label="Previous"
              aria-controls="Slider-{{ section.id }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </button>
            <div
              class="grid grid--1-col slider slider--everywhere"
              id="Slider-{{ section.id }}"
              aria-live="polite"
              aria-atomic="true"
              data-autoplay="{{ section.settings.auto_rotate }}"
              data-speed="{{ section.settings.change_slides_speed }}"
            >
              {%- for block in section.blocks -%}
                <div
                  class="slideshow__slide slider__slide grid__item grid--1-col"
                  id="Slide-{{ section.id }}-{{ forloop.index }}"
                  {{ block.shopify_attributes }}
                  role="group"
                  aria-label="{{ forloop.index }} of {{ forloop.length }}"
                  tabindex="-1"
                >
                  <div class="announcement-bar__announcement" role="region" aria-label="Announcement">
                    {%- if block.settings.text != blank -%}
                      {%- if block.settings.link != blank -%}
                        <a href="{{ block.settings.link }}" class="announcement-bar__link link link--text focus-inset animate-arrow">
                      {%- endif -%}
                      <p class="announcement-bar__message">
                        <span>{{ block.settings.text | escape }}</span>
                      </p>
                      {%- if block.settings.link != blank -%}
                        </a>
                      {%- endif -%}
                    {%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
            <button
              type="button"
              class="slider-button slider-button--next"
              name="next"
              aria-label="Next"
              aria-controls="Slider-{{ section.id }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>
        </slideshow-component>
      {%- endif -%}
    </div>

    <div class="top-bar__right">
      {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
        <localization-form>
          {%- form 'localization', id: 'TopBarCountryForm', class: 'localization-form' -%}
            <div>
              <h2 class="visually-hidden" id="TopBarCountryLabel">{{ 'localization.country_label' | t }}</h2>
              {%- render 'country-localization', localPosition: 'TopBarCountry' -%}
            </div>
          {%- endform -%}
        </localization-form>
      {% endif %}

      {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
        <localization-form>
          {%- form 'localization', id: 'TopBarLanguageForm', class: 'localization-form' -%}
            <div>
              <h2 class="visually-hidden" id="TopBarLanguageLabel">{{ 'localization.language_label' | t }}</h2>
              {%- render 'language-localization', localPosition: 'TopBarLanguage' -%}
            </div>
          {%- endform -%}
        </localization-form>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Top Bar",
  "class": "top-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "default": "#111111",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "default": "#ffffff",
      "label": "Text / Icon Color"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "default": true,
      "label": "Show social icons"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": true,
      "label": "Enable country/region selector"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": true,
      "label": "Enable language selector"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Change slides every",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Coats—every friday 75% Off . Shop Sale",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Top Bar",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}
