<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&display=swap" rel="stylesheet">
{{ 'component-image-with-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-hero-reviews {
    --text-color: {{ section.settings.text_color }};
    --bg-color: {{ section.settings.bg_color }};
    --accent-color: #e7a621;
    position: relative;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
    background-color: var(--bg-color);
    font-family: 'Poppins', sans-serif !important;
  }

  .custom-hero-reviews__container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 2rem;
    box-sizing: border-box;
  }

  .custom-hero-reviews__grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .custom-hero-reviews__grid--reverse {
    direction: rtl;
  }
  .custom-hero-reviews__grid--reverse > * {
    direction: ltr;
  }

  /* Content styles */
  .custom-hero-reviews__content-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .custom-hero-reviews__rating {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .custom-hero-reviews__stars {
    display: flex;
    gap: 0.2rem;
  }

  .custom-hero-reviews__star svg {
    display: block;
    width: 20px;
    height: 20px;
  }

  .custom-hero-reviews__rating-text {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--text-color);
  }

  /* Customer Badge */
  .custom-hero-reviews__customer-badge {
    display: inline-flex;
    align-items: center;
    gap: 1.2rem;
    border: 1.5px solid var(--text-color);
    border-radius: 100px;
    background-color: #FFFFFF;
    padding: 0.6rem 1.8rem 0.6rem 0.8rem;
    margin-bottom: 2.5rem;
  }

  .custom-hero-reviews__avatars {
    display: flex;
    align-items: center;
  }

  .custom-hero-reviews__avatar-wrapper {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid #FFFFFF;
    box-shadow: 0 0 0 1.5px var(--text-color);
    margin-left: -12px;
    position: relative;
    background: #FFFFFF;
  }

  .custom-hero-reviews__avatar-wrapper:first-child {
    margin-left: 0;
  }

  .custom-hero-reviews__avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .custom-hero-reviews__badge-text {
    font-size: 1.3rem;
    color: var(--text-color);
    font-weight: 600;
    white-space: nowrap;
  }

  .custom-hero-reviews__badge-text-bold {
    font-weight: 800;
  }

  /* Heading & Typography */
  .custom-hero-reviews__heading {
    font-family: 'Poppins', sans-serif !important;
    font-size: clamp(2.8rem, 4vw, 4.4rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-color);
    text-transform: uppercase;
    margin: 0 0 1.5rem 0;
  }

  .custom-hero-reviews__subheading {
    font-size: clamp(1.5rem, 2vw, 1.8rem);
    line-height: 1.4;
    color: var(--text-color);
    margin-bottom: 3.5rem;
    opacity: 0.95;
  }

  .custom-hero-reviews__subheading p {
    margin: 0;
  }

  /* Button and row */
  .custom-hero-reviews__cta-wrapper {
    width: 100%;
    max-width: 500px;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    align-items: stretch;
  }
  @media screen and (max-width: 989px) {
    .custom-hero-reviews__cta-wrapper {
      max-width: 100%;
    }
  }

  .custom-hero-btn {
    display: block;
    width: 100%;
    box-sizing: border-box;
    background-color: var(--accent-color);
    color: white;
    font-weight: 800;
    font-size: 1.6rem;
    padding: 1.8rem 4rem;
    border-radius: 12px;
    border: 2.5px solid var(--text-color);
    box-shadow: 0px 4px 0px 0px var(--text-color);
    text-decoration: none;
    text-align: center;
    transition: all 0.15s ease-in-out;
    cursor: pointer;
    text-transform: none;
    letter-spacing: 0.02em;
  }

  .custom-hero-btn:hover {
    transform: translateY(2px);
    box-shadow: 0px 2px 0px 0px var(--text-color);
  }

  .custom-hero-btn:active {
    transform: translateY(4px);
    box-shadow: 0px 0px 0px 0px var(--text-color);
  }

  /* Trust badges row */
  .custom-hero-reviews__trust-row {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 1.5rem;
    margin-top: 0.5rem;
    white-space: nowrap;
  }

  .custom-hero-reviews__trust-item {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding-right: 1.5rem;
    border-right: 1.5px solid color-mix(in srgb, var(--text-color) 25%, transparent);
  }

  .custom-hero-reviews__trust-item:last-child {
    border-right: none;
    padding-right: 0;
  }

  .custom-hero-reviews__trust-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-hero-reviews__trust-icon svg {
    display: block;
    width: 20px;
    height: 20px;
  }

  .custom-hero-reviews__trust-text {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text-color);
  }

  .custom-hero-reviews__checkmark-bg {
    fill: var(--accent-color) !important;
    stroke: none !important;
  }
  
  .custom-hero-reviews__checkmark-border {
    fill: none !important;
    stroke: var(--text-color) !important;
    stroke-width: 1.25px !important;
  }

  .custom-hero-reviews__checkmark-line {
    fill: none !important;
    stroke: var(--text-color) !important;
    stroke-width: 1.25px !important;
  }

  @media screen and (max-width: 989px) {
    .custom-hero-reviews__trust-row {
      flex-wrap: wrap;
      white-space: normal;
      gap: 1rem 1.5rem;
    }
    .custom-hero-reviews__trust-item {
      border-right: none;
      padding-right: 0;
    }
  }

  /* Slider column styles */
  .custom-hero-reviews__slider-col {
    position: relative;
    width: 100%;
  }

  .custom-slider {
    position: relative;
    width: 100%;
  }

  .custom-slider__mask {
    position: relative;
    overflow: hidden !important;
    width: 100%;
    border-radius: 16px;
    z-index: 1;
  }

  .custom-slider__track {
    display: flex;
    flex-wrap: nowrap;
    align-items: flex-start;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .custom-slider__slide {
    min-width: 100%;
    flex-shrink: 0;
    box-sizing: border-box;
    padding: 8px 4px;
  }

  .custom-slider__card {
    position: relative;
    background: #FFFFFF;
    border: 2px solid var(--text-color);
    border-radius: 16px;
    box-shadow: 0px 8px 16px rgba(44, 38, 9, 0.05);
    box-sizing: border-box;
    overflow: hidden;
  }

  .custom-slider__image {
    display: block;
    width: 100% !important;
    height: auto !important;
  }

  .custom-slider__split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    width: 100%;
    position: relative;
  }

  .custom-slider__split-col {
    position: relative;
    width: 100%;
  }

  .custom-slider__split-col:first-child {
    border-right: 2px solid var(--text-color);
  }

  .custom-slider__single {
    position: relative;
    width: 100%;
  }

  /* Labels overlay */
  .custom-slider__label {
    position: absolute;
    bottom: 1.5rem;
    border: 2.5px solid var(--text-color);
    padding: 0.6rem 1.4rem;
    border-radius: 100px;
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    box-shadow: 0px 2px 0px 0px var(--text-color);
    z-index: 2;
  }

  .custom-slider__label--left {
    left: 1.5rem;
    background: #FFFFFF;
    color: var(--text-color);
  }

  .custom-slider__label--right {
    right: 1.5rem;
    background: var(--accent-color);
    color: var(--text-color);
  }

  /* Dots */
  .custom-slider__dots {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    margin-top: 2rem;
  }

  .custom-slider__dot {
    width: 16px;
    height: 3px;
    border-radius: 2px;
    background-color: #C0BCA9;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all 0.25s ease;
  }

  .custom-slider__dot.is-active {
    background-color: var(--text-color);
  }

  /* Medium screens & small laptops */
  @media screen and (max-width: 1280px) {
    .custom-hero-reviews__grid {
      gap: 3rem;
    }
    .custom-hero-reviews__heading {
      font-size: clamp(2.4rem, 3.5vw, 3.8rem);
    }
    .custom-hero-reviews__subheading {
      margin-bottom: 2.5rem;
    }
  }

  /* Responsive Design */
  @media screen and (max-width: 989px) {
    .custom-hero-reviews__grid {
      grid-template-columns: 1fr;
      gap: 3.5rem;
    }

    .custom-hero-reviews__content-col {
      align-items: center;
      text-align: center;
    }

    .custom-hero-reviews__rating {
      justify-content: center;
    }

    .custom-hero-reviews__customer-badge {
      justify-content: center;
    }

    .custom-hero-reviews__cta-wrapper {
      align-items: center;
    }

    .custom-hero-btn {
      width: 100%;
      max-width: 380px;
    }

    .custom-hero-reviews__trust-row {
      justify-content: center;
      gap: 1rem 1.8rem;
    }

    .custom-hero-reviews__trust-divider {
      display: none;
    }

    .custom-slider__label {
      bottom: 1.8rem;
      padding: 0.5rem 1rem;
      font-size: 1rem;
    }

    .custom-slider__label--left {
      left: 1.8rem;
    }

    .custom-slider__label--right {
      right: 1.8rem;
    }
  }

  @media screen and (max-width: 480px) {
    .custom-hero-reviews__container {
      padding: 0 1.5rem;
    }

    .custom-hero-reviews__customer-badge {
      display: inline-flex;
      flex-direction: row;
      align-items: center;
      justify-content: center;
      gap: 1.2rem;
      border-radius: 120px;
      padding: 0.8rem 1.8rem 0.8rem 1rem;
      width: fit-content;
      max-width: 100%;
    }

    .custom-hero-reviews__avatar-wrapper {
      width: 36px;
      height: 36px;
    }

    .custom-hero-reviews__avatar-wrapper:first-child {
      margin-left: 0;
    }

    .custom-hero-reviews__avatars {
      margin-bottom: 0.2rem;
    }

    .custom-hero-reviews__trust-row {
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      width: 100%;
    }

    .custom-hero-reviews__trust-item {
      justify-content: center;
      width: 100%;
    }
  }
{%- endstyle -%}

<div class="custom-hero-reviews section-{{ section.id }}-padding">
  <div class="custom-hero-reviews__container">
    <div class="custom-hero-reviews__grid {% if section.settings.layout_desktop == 'right_content' %}custom-hero-reviews__grid--reverse{% endif %}">
      
      <!-- Content Column -->
      <div class="custom-hero-reviews__content-col">
        
        <!-- Stars Rating -->
        {%- if section.settings.show_rating -%}
          <div class="custom-hero-reviews__rating">
            <div class="custom-hero-reviews__stars">
              {%- for i in (1..section.settings.stars_count) -%}
                <span class="custom-hero-reviews__star">
                  <svg width="20" height="21" viewBox="0 0 20 21" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9.60502 2.4125C9.64153 2.33872 9.69795 2.27661 9.76789 2.23319C9.83784 2.18977 9.91852 2.16676 10.0008 2.16676C10.0832 2.16676 10.1639 2.18977 10.2338 2.23319C10.3037 2.27661 10.3602 2.33872 10.3967 2.4125L12.3217 6.31167C12.4485 6.56831 12.6357 6.79034 12.8672 6.95871C13.0987 7.12708 13.3676 7.23676 13.6508 7.27833L17.9559 7.90833C18.0374 7.92015 18.1141 7.95456 18.1771 8.00767C18.2401 8.06077 18.287 8.13046 18.3125 8.20884C18.338 8.28722 18.3411 8.37117 18.3213 8.4512C18.3016 8.53122 18.2599 8.60413 18.2008 8.66167L15.0875 11.6933C14.8822 11.8934 14.7286 12.1404 14.6399 12.413C14.5512 12.6856 14.5301 12.9757 14.5783 13.2583L15.3133 17.5417C15.3277 17.6232 15.3189 17.7071 15.2879 17.7839C15.2569 17.8607 15.205 17.9272 15.138 17.9758C15.071 18.0245 14.9917 18.0533 14.9091 18.0591C14.8265 18.0648 14.7439 18.0472 14.6708 18.0083L10.8225 15.985C10.5689 15.8519 10.2868 15.7823 10.0004 15.7823C9.71403 15.7823 9.43192 15.8519 9.17835 15.985L5.33085 18.0083C5.25779 18.047 5.17535 18.0644 5.09289 18.0585C5.01044 18.0527 4.93128 18.0238 4.86443 17.9752C4.79758 17.9266 4.74571 17.8602 4.71473 17.7835C4.68375 17.7069 4.6749 17.6231 4.68918 17.5417L5.42335 13.2592C5.47185 12.9764 5.45084 12.6862 5.36213 12.4134C5.27343 12.1406 5.11969 11.8935 4.91418 11.6933L1.80085 8.6625C1.74134 8.60503 1.69918 8.532 1.67915 8.45173C1.65913 8.37146 1.66205 8.28718 1.68758 8.20849C1.71312 8.1298 1.76024 8.05987 1.82358 8.00665C1.88692 7.95344 1.96393 7.91908 2.04585 7.9075L6.35002 7.27833C6.63356 7.23708 6.90284 7.12755 7.13467 6.95916C7.3665 6.79076 7.55394 6.56856 7.68085 6.31167L9.60502 2.4125Z" fill="var(--accent-color)" stroke="var(--text-color)" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </span>
              {%- endfor -%}
            </div>
            <span class="custom-hero-reviews__rating-text">{{ section.settings.rating_text }}</span>
          </div>
        {%- endif -%}

        <!-- Customer Badge -->
        {%- if section.settings.show_badge -%}
          <div class="custom-hero-reviews__customer-badge">
            <div class="custom-hero-reviews__avatars">
              <div class="custom-hero-reviews__avatar-wrapper">
                {%- if section.settings.badge_image_1 != blank -%}
                  {{ section.settings.badge_image_1 | image_url: width: 80, height: 80 | image_tag: loading: 'lazy', class: 'custom-hero-reviews__avatar' }}
                {%- else -%}
                  <img src="https://evilgoods.com/cdn/shop/files/tabs-section.png?v=1751628325&width=100" class="custom-hero-reviews__avatar" alt="" loading="lazy">
                {%- endif -%}
              </div>
              <div class="custom-hero-reviews__avatar-wrapper">
                {%- if section.settings.badge_image_2 != blank -%}
                  {{ section.settings.badge_image_2 | image_url: width: 80, height: 80 | image_tag: loading: 'lazy', class: 'custom-hero-reviews__avatar' }}
                {%- else -%}
                  <img src="https://evilgoods.com/cdn/shop/files/review1.png?v=1745559626&width=100" class="custom-hero-reviews__avatar" alt="" loading="lazy">
                {%- endif -%}
              </div>
              <div class="custom-hero-reviews__avatar-wrapper">
                {%- if section.settings.badge_image_3 != blank -%}
                  {{ section.settings.badge_image_3 | image_url: width: 80, height: 80 | image_tag: loading: 'lazy', class: 'custom-hero-reviews__avatar' }}
                {%- else -%}
                  <img src="https://evilgoods.com/cdn/shop/files/review5.png?v=1745559626&width=100" class="custom-hero-reviews__avatar" alt="" loading="lazy">
                {%- endif -%}
              </div>
            </div>
            <div class="custom-hero-reviews__badge-text">
              <span class="custom-hero-reviews__badge-text-bold">{{ section.settings.badge_text_bold }}</span> {{ section.settings.badge_text }}
            </div>
          </div>
        {%- endif -%}

        <!-- Heading & Subheading -->
        <h1 class="custom-hero-reviews__heading">{{ section.settings.heading }}</h1>
        <div class="custom-hero-reviews__subheading rte">{{ section.settings.subheading }}</div>

        <!-- Button & Trust Badges -->
        <div class="custom-hero-reviews__cta-wrapper">
          {%- if section.settings.button_text != blank -%}
            <a href="{{ section.settings.button_link }}" class="custom-hero-btn">
              {{ section.settings.button_text }}
            </a>
          {%- endif -%}

          <!-- Trust Badges Row -->
          {%- assign has_trust_badges = false -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'trust_badge' -%}
              {%- assign has_trust_badges = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if has_trust_badges -%}
            <div class="custom-hero-reviews__trust-row">
              {%- for block in section.blocks -%}
                {%- if block.type == 'trust_badge' -%}
                  <div class="custom-hero-reviews__trust-item" {{ block.shopify_attributes }}>
                    <span class="custom-hero-reviews__trust-icon">
                      <svg width="21" height="20" viewBox="0 0 21 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <g clip-path="url(#clip0_4501_16779_{{ block.id }})">
                          <path class="custom-hero-reviews__checkmark-bg" d="M10.5006 19.2857C15.629 19.2857 19.7863 15.1284 19.7863 10C19.7863 4.87165 15.629 0.714294 10.5006 0.714294C5.3722 0.714294 1.21484 4.87165 1.21484 10C1.21484 15.1284 5.3722 19.2857 10.5006 19.2857Z" fill="var(--accent-color)"></path>
                          <path class="custom-hero-reviews__checkmark-border" d="M10.5006 19.2857C15.629 19.2857 19.7863 15.1284 19.7863 10C19.7863 4.87165 15.629 0.714294 10.5006 0.714294C5.3722 0.714294 1.21484 4.87165 1.21484 10C1.21484 15.1284 5.3722 19.2857 10.5006 19.2857Z" stroke="var(--text-color)" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"></path>
                          <path class="custom-hero-reviews__checkmark-line" d="M14.6671 6.78574L8.95285 13.9286L6.0957 11.7857" stroke="var(--text-color)" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"></path>
                        </g>
                        <defs>
                          <clipPath id="clip0_4501_16779_{{ block.id }}">
                            <rect width="20" height="20" fill="white" transform="translate(0.5)"></rect>
                          </clipPath>
                        </defs>
                      </svg>
                    </span>
                    <span class="custom-hero-reviews__trust-text">{{ block.settings.badge_text }}</span>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>

      </div>

      <!-- Slider Column -->
      <div class="custom-hero-reviews__slider-col">
        {%- assign has_slides = false -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'slide' -%}
            {%- assign has_slides = true -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if has_slides -%}
          <div class="custom-slider" id="Slider-{{ section.id }}" data-autoplay="{{ section.settings.autoplay }}" data-autoplay-speed="{{ section.settings.autoplay_speed | times: 1000 }}">
            <div class="custom-slider__mask">
              <div class="custom-slider__track">
                {%- assign slide_index = 0 -%}
                {%- for block in section.blocks -%}
                  {%- if block.type == 'slide' -%}
                    <div class="custom-slider__slide" data-index="{{ slide_index }}" data-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
                        <div class="custom-slider__card">
                          {%- if block.settings.slide_image != blank -%}
                            <!-- Single Image Mode -->
                            <div class="custom-slider__single">
                              {{ block.settings.slide_image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'custom-slider__image' }}

                              {%- if block.settings.label_left != blank -%}
                                <div class="custom-slider__label custom-slider__label--left">
                                  {{ block.settings.label_left }}
                                </div>
                              {%- endif -%}
                              {%- if block.settings.label_right != blank -%}
                                <div class="custom-slider__label custom-slider__label--right">
                                  {{ block.settings.label_right }}
                                </div>
                              {%- endif -%}
                            </div>
                          {%- else -%}
                            <!-- Fallback Mock Mode -->
                            <div class="custom-slider__single">
                              {%- assign fallback_img = '' -%}
                              {%- assign rem = slide_index | modulo: 3 -%}
                              {%- if rem == 0 -%}
                                {%- assign fallback_img = 'customer-r3.png' -%}
                              {%- elsif rem == 1 -%}
                                {%- assign fallback_img = 'customer-r2.png' -%}
                              {%- else -%}
                                {%- assign fallback_img = 'customer-r1.png' -%}
                              {%- endif -%}
                              <img src="https://evilgoods.com/cdn/shop/files/{{ fallback_img }}?v=1745559626" class="custom-slider__image" alt="" loading="lazy">

                              {%- if block.settings.label_left != blank -%}
                                <div class="custom-slider__label custom-slider__label--left">
                                  {{ block.settings.label_left }}
                                </div>
                              {%- endif -%}
                              {%- if block.settings.label_right != blank -%}
                                <div class="custom-slider__label custom-slider__label--right">
                                  {{ block.settings.label_right }}
                                </div>
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                        </div>
                    </div>
                    {%- assign slide_index = slide_index | plus: 1 -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
            
            <!-- Slider Navigation (Dots) -->
            {%- if slide_index > 1 -%}
              <div class="custom-slider__dots">
                {%- assign slide_index_dot = 0 -%}
                {%- for block in section.blocks -%}
                  {%- if block.type == 'slide' -%}
                    <button class="custom-slider__dot{% if slide_index_dot == 0 %} is-active{% endif %}" data-slide-to="{{ slide_index_dot }}" aria-label="Go to slide {{ slide_index_dot | plus: 1 }}"></button>
                    {%- assign slide_index_dot = slide_index_dot | plus: 1 -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

<script>
  class CustomHeroSlider {
    constructor(container) {
      this.container = container;
      this.track = container.querySelector('.custom-slider__track');
      this.slides = Array.from(container.querySelectorAll('.custom-slider__slide'));
      this.dots = Array.from(container.querySelectorAll('.custom-slider__dot'));
      this.currentIndex = 0;
      this.autoplay = container.dataset.autoplay === 'true';
      this.autoplaySpeed = parseInt(container.dataset.autoplaySpeed) || 4000;
      this.autoplayTimer = null;

      // Set dynamic widths on initialization to support bulletproof responsive scaling
      const slidesCount = this.slides.length;
      this.track.style.width = `${slidesCount * 100}%`;
      this.slides.forEach(slide => {
        slide.style.width = `${100 / slidesCount}%`;
        slide.style.minWidth = `${100 / slidesCount}%`;
        slide.style.flex = `0 0 ${100 / slidesCount}%`;
      });

      this.init();
    }

    init() {
      // Dot click listeners
      this.dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          this.goToSlide(index);
          this.stopAutoplay();
        });
      });

      // Touch Swipe listeners
      let startX = 0;
      let currentX = 0;
      let isSwiping = false;

      this.track.addEventListener('touchstart', (e) => {
        startX = e.touches[0].clientX;
        isSwiping = true;
        this.stopAutoplay();
      }, { passive: true });

      this.track.addEventListener('touchmove', (e) => {
        if (!isSwiping) return;
        currentX = e.touches[0].clientX;
      }, { passive: true });

      this.track.addEventListener('touchend', () => {
        if (!isSwiping) return;
        isSwiping = false;
        const diffX = startX - currentX;
        if (Math.abs(diffX) > 50) {
          if (diffX > 0) {
            this.nextSlide();
          } else {
            this.prevSlide();
          }
        }
      });

      // Start Autoplay
      this.startAutoplay();

      // Pause autoplay on mouse hover
      this.container.addEventListener('mouseenter', () => this.stopAutoplay());
      this.container.addEventListener('mouseleave', () => this.startAutoplay());
    }

    goToSlide(index) {
      if (index < 0) {
        index = this.slides.length - 1;
      } else if (index >= this.slides.length) {
        index = 0;
      }
      this.currentIndex = index;
      
      // Update transform
      this.track.style.transform = `translate3d(-${index * (100 / this.slides.length)}%, 0, 0)`;

      // Update dots
      this.dots.forEach((dot, i) => {
        if (i === index) {
          dot.classList.add('is-active');
        } else {
          dot.classList.remove('is-active');
        }
      });
    }

    nextSlide() {
      this.goToSlide(this.currentIndex + 1);
    }

    prevSlide() {
      this.goToSlide(this.currentIndex - 1);
    }

    startAutoplay() {
      if (!this.autoplay) return;
      this.stopAutoplay();
      this.autoplayTimer = setInterval(() => {
        this.nextSlide();
      }, this.autoplaySpeed);
    }

    stopAutoplay() {
      if (this.autoplayTimer) {
        clearInterval(this.autoplayTimer);
        this.autoplayTimer = null;
      }
    }
  }

  function initCustomHeroSliders() {
    document.querySelectorAll('.custom-slider').forEach((sliderEl) => {
      if (!sliderEl.classList.contains('js-initialized')) {
        new CustomHeroSlider(sliderEl);
        sliderEl.classList.add('js-initialized');
      }
    });
  }

  // Run on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCustomHeroSliders);
  } else {
    initCustomHeroSliders();
  }

  // Run on Shopify theme editor panel updates
  document.addEventListener('shopify:section:load', function(event) {
    const sectionContainer = event.target.querySelector('.custom-slider');
    if (sectionContainer) {
      new CustomHeroSlider(sectionContainer);
      sectionContainer.classList.add('js-initialized');
    }
  });

  document.addEventListener('shopify:block:select', function(event) {
    const blockId = event.detail.blockId;
    const slideEl = event.target.querySelector(`[data-block-id="${blockId}"]`);
    if (slideEl) {
      const index = parseInt(slideEl.dataset.index);
      const sliderEl = slideEl.closest('.custom-slider');
      if (sliderEl) {
        // Find or initialize instance
        const track = sliderEl.querySelector('.custom-slider__track');
        const slides = Array.from(sliderEl.querySelectorAll('.custom-slider__slide'));
        const slidesCount = slides.length || 1;
        track.style.width = `${slidesCount * 100}%`;
        slides.forEach(slide => {
          slide.style.width = `${100 / slidesCount}%`;
          slide.style.minWidth = `${100 / slidesCount}%`;
          slide.style.flex = `0 0 ${100 / slidesCount}%`;
        });
        track.style.transform = `translate3d(-${index * (100 / slidesCount)}%, 0, 0)`;
        const dots = Array.from(sliderEl.querySelectorAll('.custom-slider__dot'));
        dots.forEach((dot, i) => {
          if (i === index) dot.classList.add('is-active');
          else dot.classList.remove('is-active');
        });
      }
    }
  });
</script>

