{{ 'page-contact.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign section_st = section.settings
  assign section_width = section_st.section_width
  assign color_scheme = section_st.color_scheme
  assign scroll_animation = settings.scroll_animation
-%}

<div class="section contact-page-wrap color-{{ color_scheme }} gradient">
  <div class="{{ section_width }}">

    {%- comment -%} ── 4 Icon Action Cards ── {%- endcomment -%}
    <div class="contact-action-cards">
      {%- for block in section.blocks -%}
        {%- if block.type == 'icon_card' -%}
          {%- liquid
            assign card_label = block.settings.label
            assign card_icon  = block.settings.icon
            assign card_link  = block.settings.link
          -%}
          <a href="{{ card_link | default: '#' }}" class="contact-action-card" {{ block.shopify_attributes }}>
            <div class="contact-action-card__icon">
              {%- case card_icon -%}
                {%- when 'track' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  <span class="contact-action-card__badge badge-blue">
                    <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="white"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14" stroke="white" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
                  </span>
                {%- when 'return' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                  <span class="contact-action-card__badge badge-blue">
                    <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.85"/></svg>
                  </span>
                {%- when 'cancel' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                  <span class="contact-action-card__badge badge-red">
                    <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </span>
                {%- when 'report' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                  <span class="contact-action-card__badge badge-yellow">
                    <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="white"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/></svg>
                  </span>
              {%- endcase -%}
            </div>
            <span class="contact-action-card__label">{{ card_label }}</span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} ── Two-column: Form + Info ── {%- endcomment -%}
    <div class="contact-two-col">

      {%- comment -%} LEFT: Contact Form {%- endcomment -%}
      {%- assign form_block = section.blocks | where: 'type', 'contact_form' | first -%}
      {%- if form_block -%}
        {%- liquid
          assign fb             = form_block.settings
          assign form_heading   = fb.heading       | default: 'Contact us'
          assign field_name     = fb.name          | default: 'Full name'
          assign field_email    = fb.email         | default: 'Email'
          assign field_message  = fb.message       | default: 'Message'
          assign field_subject  = fb.subject_label | default: 'Subject'
          assign btn_label      = fb.button_label  | default: 'Send'
          assign show_privacy   = fb.show_privacy
          assign show_attach    = fb.show_attach
          assign show_subject   = fb.show_subject
        -%}
        <div class="contact-col contact-col--form" {{ form_block.shopify_attributes }}>
          <h2 class="contact-form-heading">{{ form_heading }}</h2>

          {% form 'contact', id: 'contact_form_main' %}
            {% if form.posted_successfully? %}
              <p class="contact-success-msg">
                <svg width="18" height="18" fill="none"><g stroke="#137F24" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.3"><path d="m6.033 8.992 1.972 1.98 3.952-3.96"/><path d="M7.973 1.178c.565-.482 1.49-.482 2.062 0l1.293 1.113c.245.213.704.385 1.03.385h1.392c.867 0 1.579.712 1.579 1.579v1.39c0 .32.172.786.384 1.032l1.113 1.292c.483.565.483 1.49 0 2.062l-1.113 1.293a1.813 1.813 0 0 0-.384 1.03v1.392c0 .867-.712 1.579-1.58 1.579h-1.39c-.32 0-.786.172-1.031.384l-1.293 1.113c-.564.483-1.489.483-2.062 0L6.681 15.71a1.813 1.813 0 0 0-1.031-.384H4.234c-.867 0-1.579-.712-1.579-1.58v-1.398c0-.32-.172-.778-.376-1.023l-1.105-1.301c-.474-.565-.474-1.48 0-2.045L2.28 6.677c.204-.246.376-.704.376-1.023V4.247c0-.868.712-1.58 1.58-1.58H5.65c.319 0 .785-.171 1.03-.384l1.293-1.105Z"/></g></svg>
                {{ 'general.contact.success' | t }}
              </p>
            {% else %}
              {{ form.errors | default_errors }}
            {% endif %}

            <div class="contact-fields-grid">
              <div class="contact-field-wrap">
                <label class="contact-field-label" for="cf_name">{{ field_name }} <span class="required-star">*</span></label>
                <input type="text" id="cf_name" class="contact-field-input" name="contact[name]"
                  {% if form.name %}value="{{ form.name }}"{% elsif customer %}value="{{ customer.name }}"{% endif %}
                  required placeholder="">
              </div>
              <div class="contact-field-wrap">
                <label class="contact-field-label" for="cf_email">{{ field_email }} <span class="required-star">*</span></label>
                <input type="email" id="cf_email" class="contact-field-input" name="contact[email]" placeholder="your@email.com" required>
              </div>
            </div>

            {%- if show_subject -%}
              <div class="contact-field-wrap contact-field-wrap--full">
                <label class="contact-field-label" for="cf_subject">{{ field_subject }} <span class="required-star">*</span></label>
                <div class="contact-select-wrap">
                  <select id="cf_subject" class="contact-field-input contact-field-select" name="contact[subject]" required>
                    <option value="" disabled selected>Select a subject</option>
                    <option value="Track order">Track order</option>
                    <option value="Return order">Return order</option>
                    <option value="Cancel order">Cancel order</option>
                    <option value="Report issue">Report issue</option>
                    <option value="Other">Other</option>
                  </select>
                  <span class="contact-select-arrow">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                  </span>
                </div>
              </div>
            {%- endif -%}

            <div class="contact-field-wrap contact-field-wrap--full">
              <label class="contact-field-label" for="cf_message">{{ field_message }} <span class="required-star">*</span></label>
              <textarea id="cf_message" class="contact-field-input contact-field-textarea" name="contact[body]" placeholder="" required></textarea>
            </div>

            {%- if show_attach -%}
              <div class="contact-attach-wrap">
                <label for="cf_files" class="contact-attach-btn">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                  Attach Files
                </label>
                <input type="file" id="cf_files" name="contact[files]" multiple accept=".jpg,.jpeg,.png,.pdf,.doc,.docx" style="display:none">
                <p class="contact-attach-hint">Attach up to 10 files. The maximum allowed size per file is 10 MB.</p>
              </div>
            {%- endif -%}

            <terms-conditions class="contact-form-action">
              {%- if show_privacy -%}
                <div class="contact-privacy-row">
                  <div class="checkbox-group relative">
                    <input class="input w-20 h-20 m-0 opacity-0 absolute inset-0 pointer conditions_form_minicart"
                      type="checkbox" name="conditions" id="contact_privacy">
                    <span class="checkmark relative me-10 pointer-none pointer inline-flex"></span>
                  </div>
                  <label for="contact_privacy">{{ 'general.policies_html' | t }}</label>
                </div>
              {%- endif -%}
              <button id="contact-submit-btn"
                class="contact-submit-btn {% if show_privacy == false %} active{% endif %}"
                type="submit"
                {% if show_privacy == true %}disabled{% endif %}>
                {{ btn_label | default: 'Send' }}
              </button>
            </terms-conditions>

            {%- if show_privacy -%}
              <p class="contact-recaptcha-note">
                This site is protected by reCAPTCHA. For more information, please refer to Gorgias'
                <a href="/policies/privacy-policy">Privacy Policy</a>.
              </p>
            {%- endif -%}
          {% endform %}
        </div>
      {%- endif -%}

      {%- comment -%} LEFT: Contact Info + Map ── {%- endcomment -%}
      {%- assign info_block = section.blocks | where: 'type', 'contact_info' | first -%}
      {%- if info_block -%}
        {%- liquid
          assign ib          = info_block.settings
          assign info_heading = ib.heading  | default: 'Get in touch'
          assign phone       = ib.phone
          assign call_label  = ib.call_label | default: 'Call Us'
          assign email_addr  = ib.email
          assign address     = ib.address
          assign map_iframe  = ib.map_iframe
        -%}
        <div class="contact-col contact-col--info contact-col--order-first" {{ info_block.shopify_attributes }}>
          {% if info_heading != blank %}
            <h2 class="contact-info-heading">{{ info_heading }}</h2>
          {% endif %}

          <div class="contact-info-items">
            {%- if phone != blank -%}
              <div class="contact-info-item">
                <div class="contact-info-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.59 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.78a16 16 0 0 0 6 6l.91-1.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 15l.19 1.92z"/></svg>
                </div>
                <div class="contact-info-text">
                  <span class="contact-info-label">{{ call_label }}</span>
                  <a href="tel:{{ phone | replace: ' ', '' }}" class="contact-info-value">{{ phone }}</a>
                </div>
              </div>
            {%- endif -%}

            {%- if email_addr != blank -%}
              <div class="contact-info-item">
                <div class="contact-info-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <div class="contact-info-text">
                  <span class="contact-info-label">Email Us</span>
                  <a href="mailto:{{ email_addr }}" class="contact-info-value">{{ email_addr }}</a>
                </div>
              </div>
            {%- endif -%}

            {%- if address != blank -%}
              <div class="contact-info-item">
                <div class="contact-info-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <div class="contact-info-text">
                  <span class="contact-info-label">Our Address</span>
                  <span class="contact-info-value">{{ address }}</span>
                </div>
              </div>
            {%- endif -%}
          </div>

          {%- if map_iframe != blank -%}
            <div class="contact-map-wrap">
              {{ map_iframe }}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>{%- comment -%} end .contact-two-col {%- endcomment -%}
  </div>
</div>

<script src="{{ 'contact.js' | asset_url }}" defer="defer"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    var fileInput = document.getElementById('cf_files');
    if (fileInput) {
      fileInput.addEventListener('change', function() {
        var label = document.querySelector('.contact-attach-btn');
        if (label && this.files.length > 0) {
          label.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg> ' + this.files.length + ' file(s) selected';
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Contact Page",
  "tag": "section",
  "class": "overlay-section contact-us",
  "limit": 1,
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:sections.all.section_width.label",
      "default": "container",
      "options": [
        { "value": "container",      "label": "t:sections.all.section_width.container.label" },
        { "value": "fluid_container","label": "t:sections.all.section_width.fluid_container.label" },
        { "value": "stretch_width",  "label": "t:sections.all.section_width.stretch_width.label" },
        { "value": "full_width",     "label": "t:sections.all.section_width.full_width.label" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "icon_card",
      "name": "Icon Card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "track",
          "options": [
            { "value": "track",  "label": "Track Order" },
            { "value": "return", "label": "Return Order" },
            { "value": "cancel", "label": "Cancel Order" },
            { "value": "report", "label": "Report Issue" }
          ]
        },
        { "type": "text", "id": "label", "label": "Label", "default": "Track order" },
        { "type": "url",  "id": "link",  "label": "Link" }
      ]
    },
    {
      "type": "contact_form",
      "name": "Contact Form",
      "limit": 1,
      "settings": [
        { "type": "text",     "id": "heading",       "label": "Form Heading",           "default": "Contact us" },
        { "type": "text",     "id": "name",          "label": "Name field label",        "default": "Full name" },
        { "type": "text",     "id": "email",         "label": "Email field label",       "default": "Email" },
        { "type": "checkbox", "id": "show_subject",  "label": "Show Subject dropdown",   "default": true },
        { "type": "text",     "id": "subject_label", "label": "Subject field label",     "default": "Subject" },
        { "type": "text",     "id": "message",       "label": "Message field label",     "default": "Message" },
        { "type": "checkbox", "id": "show_attach",   "label": "Show Attach Files",       "default": true },
        { "type": "text",     "id": "button_label",  "label": "Submit button label",     "default": "Send" },
        { "type": "checkbox", "id": "show_privacy",  "label": "Show privacy checkbox",   "default": true }
      ]
    },
    {
      "type": "contact_info",
      "name": "Contact Information",
      "limit": 1,
      "settings": [
        { "type": "text",     "id": "heading",     "label": "Heading",          "default": "Get in touch" },
        { "type": "text",     "id": "call_label",  "label": "Call label",       "default": "Call Us" },
        { "type": "text",     "id": "phone",       "label": "Phone number",     "default": "+1 (973) 435-3638" },
        { "type": "text",     "id": "email",       "label": "Email address",    "default": "info@fashionwomen.com" },
        { "type": "textarea", "id": "address",     "label": "Address",          "default": "123 Fashion Street, New York, NY 10001, USA" },
        { "type": "textarea", "id": "map_iframe",  "label": "Google Map embed code (iframe)" }
      ]
    }
  ],
  "presets": [
    { "name": "Contact Page" }
  ]
}
{% endschema %}
