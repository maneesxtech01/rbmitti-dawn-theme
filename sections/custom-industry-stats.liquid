<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&display=swap" rel="stylesheet">

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-stats {
    --text-color: {{ section.settings.text_color }};
    --bg-color: {{ section.settings.bg_color }};
    --accent-color: {{ section.settings.accent_color }};
    --card-bg: {{ section.settings.card_bg }};
    background-color: var(--bg-color);
    color: var(--text-color);
    font-family: 'Poppins', sans-serif !important;
    position: relative;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }

  .custom-stats__container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 2rem;
    box-sizing: border-box;
  }

  .custom-stats__grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  @media screen and (max-width: 1280px) {
    .custom-stats__grid {
      gap: 3.5rem;
    }
    .custom-stats__heading {
      font-size: clamp(2.4rem, 3.5vw, 3.8rem);
    }
  }

  @media screen and (max-width: 989px) {
    .custom-stats__container {
      padding: 0 1.5rem;
    }
    .custom-stats__grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .custom-stats__media-col {
      order: 1;
    }
    .custom-stats__text-col {
      order: 2;
      align-items: center;
      text-align: center;
    }
  }

  /* Media column styles */
  .custom-stats__media-col {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  /* .custom-stats__image-wrapper {
    position: relative;
    border: 2px solid var(--text-color);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0px 8px 16px rgba(44, 38, 9, 0.03);
    background: #FFFFFF;
    width: 100%;
    max-width: 600px;
  } */

  .custom-stats__image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /* Text column styles */
  .custom-stats__text-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
  }

  .custom-stats__heading {
    font-family: 'Poppins', sans-serif !important;
    font-size: clamp(2.8rem, 4vw, 4.2rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--text-color);
    margin: 0 0 2rem 0;
  }

  .custom-stats__subheading {
    font-size: clamp(1.5rem, 2vw, 1.7rem);
    line-height: 1.5;
    color: var(--text-color);
    margin-bottom: 2.5rem;
    opacity: 0.95;
  }

  .custom-stats__subheading p {
    margin: 0;
  }

  /* Stats Card styles */
  .custom-stats__card {
    background-color: var(--card-bg);
    color: var(--text-color);
    border-radius: 16px;
    border: 2px solid var(--text-color);
    box-shadow: 0px 4px 0px 0px var(--text-color);
    overflow: hidden;
    max-width: 600px;
    width: 100%;
  }

  .custom-stats__card-header {
    background-color: var(--accent-color);
    padding: 1.4rem 2rem;
    text-align: center;
    border-bottom: 2px solid var(--text-color);
  }

  .custom-stats__card-title {
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    color: var(--text-color);
    margin: 0;
    text-transform: uppercase;
  }

  .custom-stats__card-body {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .custom-stats__row {
    display: flex;
    align-items: center;
    gap: 2rem;
    text-align: left;
  }

  .custom-stats__circle {
    background-color: color-mix(in srgb, var(--accent-color) 22%, #FFFFFF);
    min-width: 72px;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    border: 2px solid var(--text-color);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0px 2px 0px 0px var(--text-color);
  }

  .custom-stats__percentage {
    font-size: 2.2rem;
    font-weight: 900;
    color: var(--text-color);
  }

  .custom-stats__row-content {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .custom-stats__row-heading {
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: var(--text-color);
    text-transform: uppercase;
  }

  .custom-stats__row-text {
    font-size: 1.35rem;
    line-height: 1.45;
    color: var(--text-color);
    margin: 0;
    opacity: 0.9;
  }
{%- endstyle -%}

<div class="custom-stats section-{{ section.id }}-padding">
  <div class="custom-stats__container">
    <div class="custom-stats__grid">
      
      <!-- Media Column -->
      <div class="custom-stats__media-col">
        <div class="custom-stats__image-wrapper">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'custom-stats__image' }}
          {%- else -%}
            <img src="https://evilgoods.com/cdn/shop/files/Image_v2.png?v=1751627774&width=1500" class="custom-stats__image" alt="The Skincare Industry Is Lying" loading="lazy">
          {%- endif -%}
        </div>
      </div>

      <!-- Text Column -->
      <div class="custom-stats__text-col">
        <h2 class="custom-stats__heading">{{ section.settings.heading }}</h2>
        <div class="custom-stats__subheading rte">
          {{ section.settings.subheading }}
        </div>

        {%- assign has_stats = false -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'statistic' -%}
            {%- assign has_stats = true -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if has_stats -%}
          <div class="custom-stats__card">
            <div class="custom-stats__card-header">
              <p class="custom-stats__card-title">{{ section.settings.card_title }}</p>
            </div>
            <div class="custom-stats__card-body">
              {%- for block in section.blocks -%}
                {%- if block.type == 'statistic' -%}
                  <div class="custom-stats__row" {{ block.shopify_attributes }}>
                    <div class="custom-stats__circle">
                      <span class="custom-stats__percentage">{{ block.settings.percentage }}</span>
                    </div>
                    <div class="custom-stats__row-content">
                      <span class="custom-stats__row-heading">{{ block.settings.label }}</span>
                      <p class="custom-stats__row-text">{{ block.settings.description }}</p>
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Industry Statistics",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FAF9F5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#2C2609"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent / Header color",
      "default": "#e7a621"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Media Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Side image"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THE SKINCARE INDUSTRY IS LYING TO YOU"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Normal moisturizers and skin care products are loaded with toxic chemicals that don't just sit on your skin — they penetrate your bloodstream and disrupt your body from within. <strong>These aren't just ineffective — they're actively harmful.</strong></p>"
    },
    {
      "type": "text",
      "id": "card_title",
      "label": "Stats Card Title",
      "default": "SHOCKING INDUSTRY STATISTICS:"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "statistic",
      "name": "Statistic Row",
      "settings": [
        {
          "type": "text",
          "id": "percentage",
          "label": "Percentage",
          "default": "78%"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "HORMONE-DISRUPTING FRAGRANCES"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "78% of drugstore lotions contain fragrance blends that trigger inflammation, breakouts, and endocrine issues."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Industry Statistics",
      "blocks": [
        {
          "type": "statistic",
          "settings": {
            "percentage": "78%",
            "label": "HORMONE-DISRUPTING FRAGRANCES",
            "description": "78% of drugstore lotions contain fragrance blends that trigger inflammation, breakouts, and endocrine issues."
          }
        },
        {
          "type": "statistic",
          "settings": {
            "percentage": "85%",
            "label": "TESTOSTERONE-LOWERING CHEMICALS",
            "description": "85% of standard body lotions contain ingredients scientifically linked to hormone suppression and fertility problems."
          }
        },
        {
          "type": "statistic",
          "settings": {
            "percentage": "87%",
            "label": "PORE-CLOGGING PETROLEUM",
            "description": "87% of drugstore moisturizers use petroleum byproducts that create a plastic-like barrier, trapping dirt and preventing skin from breathing naturally."
          }
        }
      ]
    }
  ]
}
{% endschema %}
