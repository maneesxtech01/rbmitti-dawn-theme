<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&display=swap" rel="stylesheet">

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* =====================
     SECTION WRAPPER
  ===================== */
  .skt-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    font-family: 'Poppins', sans-serif;
    width: 100%;
    box-sizing: border-box;
    border-bottom:2px solid;
  }

  /* =====================
     CONTAINER — 1200px centered (matches .maison_commerce_container)
  ===================== */
  .skt-{{ section.id }} .skt__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    box-sizing: border-box;
  }

  /* =====================
     HEADER (matches .maison_commerce_header)
  ===================== */
  .skt-{{ section.id }} .skt__header {
    text-align: center;
    margin-bottom: 2.4rem;
  }

  .skt-{{ section.id }} .skt__title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(2.6rem, 3.8vw, 4.4rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.1;
    color: {{ section.settings.title_color }};
    margin: 0 0 0.8rem;
  }

  .skt-{{ section.id }} .skt__subtitle {
    font-size: clamp(1.3rem, 1.6vw, 1.5rem);
    font-weight: 400;
    line-height: 1.6;
    color: {{ section.settings.subtitle_color }};
    max-width: 560px;
    margin: 0 auto;
  }

  /* =====================
     TAB NAV (matches .maison_commerce_product_nav_container)
     Original: pill button, bg = page bg, border dark
  ===================== */
  .skt-{{ section.id }} .skt__nav-outer {
    display: flex;
    justify-content: center;
    overflow-x: auto;
    scrollbar-width: none;
    margin-bottom: 3.2rem;
  }
  .skt-{{ section.id }} .skt__nav-outer::-webkit-scrollbar { display: none; }

  .skt-{{ section.id }} .skt__nav {
    display: inline-flex;
    gap: 0.6rem;
    border-radius: 999px;
  }

  /* Original button: rounded pill, same bg as page, dark border, dark text */
  .skt-{{ section.id }} .skt__tab-btn {
    font-family: 'Poppins', sans-serif;
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1;
    padding: 14px 32px;
    border-radius: 999px;
   border: 5px double #f9f8f4;
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.title_color }};
    cursor: pointer;
    transition: opacity 0.2s;
    white-space: nowrap;
    letter-spacing: 0.01em;
    opacity: 0.55;
  }

  .skt-{{ section.id }} .skt__tab-btn.is-active {
    opacity: 1;
    background-color: #faedd3;
    border-color: {{ section.settings.title_color }};
    color: {{ section.settings.title_color }};
  }

  .skt-{{ section.id }} .skt__tab-btn:hover {
    opacity: 1;
  }

  /* =====================
     CONTENT PANEL
     Original: display flex, image left ~44%, ingredients right
  ===================== */
  .skt-{{ section.id }} .skt__panel { display: none; }
  .skt-{{ section.id }} .skt__panel.is-active {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 4rem;
  }

  /* Left: product image (matches .maison_commerce_product_image) */
  .skt-{{ section.id }} .skt__img-col {
    flex: 0 0 44%;
    max-width: 44%;
  }

  .skt-{{ section.id }} .skt__img-col img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 12px;
    object-fit: cover;
  }

  /* Right: ingredients grid (matches .maison_commerce_ingredients_grid) */
  .skt-{{ section.id }} .skt__ing-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  /* =====================
     INGREDIENT CARD (matches .maison_commerce_ingredient_item)
     Original: white bg, 1px border, rounded 10px, flex row,
     icon 70x70 on left, content (title + desc) on right
  ===================== */
  .skt-{{ section.id }} .skt__ing-item {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1.6rem;
    background-color: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.card_border }};
    border-radius: 10px;
    padding: 1.2rem 1.6rem;
    transition: box-shadow 0.15s ease;
  }

  .skt-{{ section.id }} .skt__ing-item:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  }

  /* Icon image (matches .maison_commerce_ingredient_image)
     Original: 70x70, no border, just the image */
  .skt-{{ section.id }} .skt__ing-icon {
    flex-shrink: 0;
    width: 70px;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .skt-{{ section.id }} .skt__ing-icon img {
    display: block;
    width: 70px;
    height: 70px;
    object-fit: contain;
  }

  /* Content (matches .maison_commerce_ingredient_content) */
  .skt-{{ section.id }} .skt__ing-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .skt-{{ section.id }} .skt__ing-title {
    font-family: 'Poppins', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: {{ section.settings.title_color }};
    margin: 0;
    line-height: 1.25;
  }

  .skt-{{ section.id }} .skt__ing-desc {
    font-family: 'Poppins', sans-serif;
    font-size: 1.2rem;
    font-weight: 400;
    line-height: 1.5;
    color: {{ section.settings.subtitle_color }};
    margin: 0;
  }

  /* =====================
     RESPONSIVE
  ===================== */
  @media screen and (max-width: 1024px) {
    .skt-{{ section.id }} .skt__panel.is-active { gap: 2.5rem; }
    .skt-{{ section.id }} .skt__img-col { flex: 0 0 40%; max-width: 40%; }
  }

  @media screen and (max-width: 768px) {
    .skt-{{ section.id }} .skt__container { padding: 0 1.5rem; }
    .skt-{{ section.id }} .skt__panel.is-active {
      flex-direction: column;
      gap: 2.5rem;
    }
    .skt-{{ section.id }} .skt__img-col { flex: 0 0 100%; max-width: 100%; }
    .skt-{{ section.id }} .skt__title { font-size: clamp(2.2rem, 7vw, 3.2rem); }
  }
{%- endstyle -%}

<div class="skt-{{ section.id }} section-{{ section.id }}-padding">
  <div class="skt__container">

    <!-- HEADER -->
    <div class="skt__header">
      <h2 class="skt__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="skt__subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <!-- TAB NAV -->
    <div class="skt__nav-outer">
      <div class="skt__nav">
        {%- assign ti = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'tab' -%}
            <button
              class="skt__tab-btn{% if ti == 0 %} is-active{% endif %}"
              data-skt-tab="{{ block.id }}"
              {{ block.shopify_attributes }}
            >{{ block.settings.tab_label }}</button>
            {%- assign ti = ti | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <!-- PANELS -->
    {%- assign pi = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'tab' -%}
        <div
          class="skt__panel{% if pi == 0 %} is-active{% endif %}"
          data-skt-panel="{{ block.id }}"
          {{ block.shopify_attributes }}
        >
          <!-- LEFT: Product Image -->
          <div class="skt__img-col">
            {%- if block.settings.product_image != blank -%}
              {{ block.settings.product_image | image_url: width: 800 | image_tag:
                loading: 'lazy',
                alt: block.settings.tab_label
              }}
            {%- endif -%}
          </div>

          <!-- RIGHT: Ingredient Cards -->
          <div class="skt__ing-col">

            {%- if block.settings.ing1_title != blank -%}
              <div class="skt__ing-item">
                <div class="skt__ing-icon">
                  {%- if block.settings.ing1_icon != blank -%}
                    {{ block.settings.ing1_icon | image_url: width: 140 | image_tag: loading: 'lazy' }}
                  {%- endif -%}
                </div>
                <div class="skt__ing-body">
                  <h3 class="skt__ing-title">{{ block.settings.ing1_title }}</h3>
                  {%- if block.settings.ing1_desc != blank -%}<p class="skt__ing-desc">{{ block.settings.ing1_desc }}</p>{%- endif -%}
                </div>
              </div>
            {%- endif -%}

            {%- if block.settings.ing2_title != blank -%}
              <div class="skt__ing-item">
                <div class="skt__ing-icon">
                  {%- if block.settings.ing2_icon != blank -%}
                    {{ block.settings.ing2_icon | image_url: width: 140 | image_tag: loading: 'lazy' }}
                  {%- endif -%}
                </div>
                <div class="skt__ing-body">
                  <h3 class="skt__ing-title">{{ block.settings.ing2_title }}</h3>
                  {%- if block.settings.ing2_desc != blank -%}<p class="skt__ing-desc">{{ block.settings.ing2_desc }}</p>{%- endif -%}
                </div>
              </div>
            {%- endif -%}

            {%- if block.settings.ing3_title != blank -%}
              <div class="skt__ing-item">
                <div class="skt__ing-icon">
                  {%- if block.settings.ing3_icon != blank -%}
                    {{ block.settings.ing3_icon | image_url: width: 140 | image_tag: loading: 'lazy' }}
                  {%- endif -%}
                </div>
                <div class="skt__ing-body">
                  <h3 class="skt__ing-title">{{ block.settings.ing3_title }}</h3>
                  {%- if block.settings.ing3_desc != blank -%}<p class="skt__ing-desc">{{ block.settings.ing3_desc }}</p>{%- endif -%}
                </div>
              </div>
            {%- endif -%}

            {%- if block.settings.ing4_title != blank -%}
              <div class="skt__ing-item">
                <div class="skt__ing-icon">
                  {%- if block.settings.ing4_icon != blank -%}
                    {{ block.settings.ing4_icon | image_url: width: 140 | image_tag: loading: 'lazy' }}
                  {%- endif -%}
                </div>
                <div class="skt__ing-body">
                  <h3 class="skt__ing-title">{{ block.settings.ing4_title }}</h3>
                  {%- if block.settings.ing4_desc != blank -%}<p class="skt__ing-desc">{{ block.settings.ing4_desc }}</p>{%- endif -%}
                </div>
              </div>
            {%- endif -%}

            {%- if block.settings.ing5_title != blank -%}
              <div class="skt__ing-item">
                <div class="skt__ing-icon">
                  {%- if block.settings.ing5_icon != blank -%}
                    {{ block.settings.ing5_icon | image_url: width: 140 | image_tag: loading: 'lazy' }}
                  {%- endif -%}
                </div>
                <div class="skt__ing-body">
                  <h3 class="skt__ing-title">{{ block.settings.ing5_title }}</h3>
                  {%- if block.settings.ing5_desc != blank -%}<p class="skt__ing-desc">{{ block.settings.ing5_desc }}</p>{%- endif -%}
                </div>
              </div>
            {%- endif -%}

          </div>
        </div>
        {%- assign pi = pi | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}

  </div>
</div>

<script>
  (function() {
    document.querySelectorAll('[data-skt-tab]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = btn.getAttribute('data-skt-tab');
        var root = btn.closest('[class*="skt-"]');
        root.querySelectorAll('.skt__tab-btn').forEach(function(b) { b.classList.remove('is-active'); });
        btn.classList.add('is-active');
        root.querySelectorAll('.skt__panel').forEach(function(p) { p.classList.remove('is-active'); });
        var panel = root.querySelector('[data-skt-panel="' + id + '"]');
        if (panel) panel.classList.add('is-active');
      });
    });
  })();
</script>

