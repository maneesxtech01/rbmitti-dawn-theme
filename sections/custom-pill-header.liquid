<!--
  Custom Premium Pill Header for Shopify Dawn Theme
  Fully dynamic, styling overrides standard Dawn headers while preserving theme integration.
-->

<!-- Include Google Font: Poppins & Font Awesome 6 Icons -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" media="print" onload="this.media='all'">

<style>
  /* --------------------------------------------------
     CSS VARIABLES & CORE CAPSULE OVERRIDES
     -------------------------------------------------- */
  :root {
    --color-primary: #F15A24; /* Evil Goods Orange */
    --color-primary-hover: #D84B1B;
    --font-primary: 'Poppins', sans-serif;
    --shadow-soft: 0 10px 30px rgba(0, 0, 0, 0.04), 0 1px 8px rgba(0, 0, 0, 0.02);
    --shadow-medium: 0 15px 40px rgba(0, 0, 0, 0.08), 0 3px 12px rgba(0, 0, 0, 0.03);
    --shadow-drawer: -10px 0 30px rgba(0, 0, 0, 0.05);
    
    --header-desktop-height: 80px;
    --header-mobile-height: 70px;
  }

  /* Reset default Dawn header styles to adopt our custom capsule style */
  .header-wrapper {
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
  }

  .section-header {
    position: relative;
    z-index: 1000;
  }

  /* --------------------------------------------------
     HEADER CAPSULE CONTAINER
     -------------------------------------------------- */
  .header-outer-container {
    width: 100%;
    padding: 20px 40px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-sizing: border-box;
  }

  .header-inner {
    background-color: #ffffff;
    border-radius: 100px;
    box-shadow: var(--shadow-soft);
    height: var(--header-desktop-height);
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 45px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-sizing: border-box;
  }

  /* Centered logo container */
  .logo-container {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    display: flex;
    align-items: center;
  }

  .logo-container img {
    height: 38px;
    width: auto;
    object-fit: contain;
    transition: height 0.3s ease;
  }

  /* --------------------------------------------------
     DESKTOP NAVIGATION (LEFT)
     -------------------------------------------------- */
  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 24px;
    height: 100%;
  }

  .nav-link {
    font-family: var(--font-primary);
    font-size: 14px;
    font-weight: 600;
    color: #000000;
    letter-spacing: 0.3px;
    position: relative;
    padding: 8px 0;
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--color-primary);
  }

  /* Underline animation */
  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: var(--color-primary);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* --------------------------------------------------
     DESKTOP ACTIONS (RIGHT)
     -------------------------------------------------- */
  .desktop-actions {
    display: flex;
    align-items: center;
    gap: 22px;
  }

  .lang-selector {
    font-family: var(--font-primary);
    font-size: 14px;
    font-weight: 600;
    color: #000000;
    cursor: pointer;
    transition: color 0.2s;
  }

  .lang-selector:hover {
    color: var(--color-primary);
  }

  .action-btn {
    font-size: 18px;
    color: #000000;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s, transform 0.2s;
  }

  .action-btn:hover {
    color: var(--color-primary);
    transform: translateY(-1px);
  }

  /* Cart Badge */
  .cart-badge {
    position: absolute;
    top: -8px;
    right: -8px;
    background-color: var(--color-primary);
    color: #ffffff;
    font-size: 10px;
    font-weight: 700;
    min-width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
    border: 2px solid #ffffff;
    font-family: var(--font-primary);
  }

  /* --------------------------------------------------
     MOBILE ACTIONS & HAMBURGER
     -------------------------------------------------- */
  .mobile-header-left,
  .mobile-header-right {
    display: none;
  }

  .mobile-hamburger {
    width: 44px;
    height: 44px;
    background-color: var(--color-primary);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    border: none;
    cursor: pointer;
    transition: background-color 0.2s, transform 0.2s;
  }

  .mobile-hamburger:hover {
    background-color: var(--color-primary-hover);
  }

  .mobile-hamburger span {
    display: block;
    width: 20px;
    height: 2px;
    background-color: #ffffff;
    border-radius: 2px;
  }

  .mobile-cart-btn {
    font-size: 24px;
    color: #000000;
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
  }

  /* --------------------------------------------------
     STICKY HEADER MODIFIERS
     -------------------------------------------------- */
  .header-outer-container.is-sticky {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    padding: 10px 24px;
    animation: slideDown 0.4s ease forwards;
  }

  .header-outer-container.is-sticky .header-inner {
    height: 68px;
    box-shadow: var(--shadow-medium);
  }

  .header-outer-container.is-sticky .logo-container img {
    height: 32px;
  }

  @keyframes slideDown {
    from { transform: translateY(-100%); }
    to { transform: translateY(0); }
  }

  /* --------------------------------------------------
     OVERLAY & DRAWERS
     -------------------------------------------------- */
  .overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    z-index: 1999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .overlay.active {
    opacity: 1;
    pointer-events: auto;
  }

  /* Sidebar (Left drawer) */
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: 320px;
    height: 100vh;
    background-color: #ffffff;
    z-index: 2000;
    transform: translateX(-100%);
    box-shadow: 10px 0 30px rgba(0, 0, 0, 0.05);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .sidebar.active {
    transform: translateX(0);
  }

  .sidebar-header {
    padding: 24px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid #eaeaea;
  }

  .sidebar-logo img {
    height: 30px;
    width: auto;
  }

  .close-btn {
    font-size: 20px;
    color: #000000;
    padding: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.2s, transform 0.2s;
  }

  .close-btn:hover {
    color: var(--color-primary);
    transform: rotate(90deg);
  }

  .sidebar-content {
    flex: 1;
    overflow-y: auto;
    padding: 24px 20px;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .sidebar-link {
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 600;
    color: #000000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 0;
    text-decoration: none;
    transition: color 0.2s;
  }

  .sidebar-link:hover,
  .sidebar-link.active {
    color: var(--color-primary);
  }

  .sidebar-link i {
    font-size: 14px;
    opacity: 0;
    transform: translateX(-10px);
    transition: opacity 0.2s, transform 0.2s;
  }

  .sidebar-link:hover i,
  .sidebar-link.active i {
    opacity: 1;
    transform: translateX(0);
  }

  .sidebar-account {
    margin-top: 30px;
    padding-top: 24px;
    border-top: 1px solid #eaeaea;
  }

  .sidebar-footer {
    padding: 24px 20px;
    border-top: 1px solid #eaeaea;
    background-color: #f7f7f7;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
  }

  .sidebar-socials {
    display: flex;
    gap: 18px;
  }

  .social-icon {
    font-size: 18px;
    color: #333333;
    text-decoration: none;
    transition: color 0.2s, transform 0.2s;
  }

  .social-icon:hover {
    color: var(--color-primary);
    transform: translateY(-2px);
  }

  /* Cart Drawer (Right Side) */
  .cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: 420px;
    max-width: 100%;
    height: 100vh;
    background-color: #ffffff;
    z-index: 2000;
    transform: translateX(100%);
    box-shadow: var(--shadow-drawer);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
  }

  .cart-drawer.active {
    transform: translateX(0);
  }

  .cart-header {
    padding: 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid #eaeaea;
  }

  .cart-title {
    font-family: var(--font-primary);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.3px;
  }

  .cart-content {
    flex: 1;
    overflow-y: auto;
    padding: 24px;
    display: flex;
    flex-direction: column;
  }

  .cart-empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: auto;
    text-align: center;
    padding: 40px 0;
  }

  .cart-empty-state i {
    font-size: 64px;
    color: #eaeaea;
    margin-bottom: 20px;
  }

  .cart-empty-state p {
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 500;
    color: #333333;
    margin-bottom: 24px;
  }

  .btn-checkout,
  .btn-secondary {
    width: 100%;
    padding: 16px;
    border-radius: 50px;
    font-family: var(--font-primary);
    font-size: 14px;
    font-weight: 600;
    text-align: center;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-checkout {
    background-color: var(--color-primary);
    color: #ffffff;
  }

  .btn-checkout:hover {
    background-color: var(--color-primary-hover);
    box-shadow: 0 4px 15px rgba(241, 90, 36, 0.3);
  }

  .btn-secondary {
    background-color: #000000;
    color: #ffffff;
    margin-top: 12px;
  }

  .btn-secondary:hover {
    background-color: #222222;
  }

  .cart-items-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .cart-item {
    display: flex;
    gap: 16px;
    padding-bottom: 20px;
    border-bottom: 1px solid #f7f7f7;
  }

  .cart-item-img {
    width: 80px;
    height: 80px;
    border-radius: 12px;
    background-color: #f7f7f7;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .cart-item-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-item-details {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .cart-item-title {
    font-family: var(--font-primary);
    font-size: 14px;
    font-weight: 600;
    color: #000000;
    line-height: 1.4;
  }

  .cart-item-price {
    font-family: var(--font-primary);
    font-size: 14px;
    font-weight: 700;
    color: var(--color-primary);
  }

  .cart-item-qty {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 8px;
  }

  .qty-val {
    font-family: var(--font-primary);
    font-size: 14px;
    font-weight: 600;
    min-width: 16px;
    text-align: center;
  }

  .cart-footer {
    padding: 24px;
    border-top: 1px solid #eaeaea;
    background-color: #f7f7f7;
    display: none;
  }

  .cart-summary-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 20px;
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 700;
  }

  /* Search Drawer */
  .search-drawer {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background-color: #ffffff;
    z-index: 2000;
    transform: translateY(-100%);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 30px 0;
  }

  .search-drawer.active {
    transform: translateY(0);
  }

  .search-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .search-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    border-bottom: 2px solid #000000;
    padding-bottom: 10px;
  }

  .search-input-wrapper i {
    font-size: 22px;
    color: #999999;
    margin-right: 15px;
  }

  .search-input {
    width: 100%;
    border: none;
    font-family: var(--font-primary);
    font-size: 22px;
    font-weight: 500;
    outline: none;
    color: #000000;
  }

  .search-close-btn {
    background: none;
    border: none;
    cursor: pointer;
    margin-left: 15px;
    font-size: 24px;
    transition: color 0.2s, transform 0.2s;
  }

  .search-close-btn:hover {
    color: var(--color-primary);
    transform: scale(1.1);
  }

  .live-search-results {
    margin-top: 24px;
    display: none;
    max-height: 400px;
    overflow-y: auto;
  }

  .live-search-results.active {
    display: block;
  }

  .results-heading {
    font-family: var(--font-primary);
    font-size: 13px;
    font-weight: 600;
    color: #999999;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 16px;
  }

  .search-product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 16px;
  }

  .search-product-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    border-radius: 12px;
    background-color: #f7f7f7;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s;
  }

  .search-product-card:hover {
    background-color: #eaeaea;
    transform: translateY(-2px);
  }

  .search-prod-img {
    width: 50px;
    height: 50px;
    border-radius: 8px;
    background-color: #ffffff;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .search-prod-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .search-prod-details {
    display: flex;
    flex-direction: column;
  }

  .search-prod-title {
    font-family: var(--font-primary);
    font-size: 13px;
    font-weight: 600;
    color: #000000;
  }

  .search-prod-price {
    font-family: var(--font-primary);
    font-size: 12px;
    font-weight: 700;
    color: var(--color-primary);
  }

  /* --------------------------------------------------
     RESPONSIVE BREAKPOINTS
     -------------------------------------------------- */
  @media (max-width: 1024px) {
    .header-outer-container {
      padding: 15px 20px;
    }
    .header-inner {
      padding: 0 25px;
    }
    .desktop-nav {
      gap: 15px;
    }
    .desktop-actions {
      gap: 15px;
    }
  }

  @media (max-width: 990px) {
    .header-outer-container {
      padding: 12px 16px;
    }

    .header-outer-container.is-sticky {
      padding: 8px 12px;
    }

    .header-inner {
      height: var(--header-mobile-height);
      border-radius: 50px;
      padding: 0 16px;
    }

    .desktop-nav,
    .desktop-actions {
      display: none;
    }

    .mobile-header-left,
    .mobile-header-right {
      display: flex;
      align-items: center;
    }

    .mobile-header-right {
      gap: 16px;
    }
  }
</style>

{%- style -%}
  .section-header {
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-header {
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }
{%- endstyle -%}

<!-- ==================================================
     MAIN PILL HEADER
     ================================================== -->
<div class="header-outer-container" id="main-header">
  <div class="header-inner">
    
    <!-- [DESKTOP] Left Side Navigation Menu -->
    <nav class="desktop-nav">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}" class="nav-link{% if link.active %} active{% endif %}">{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    <!-- [MOBILE] Left Side Hamburger Button -->
    <div class="mobile-header-left">
      <button class="mobile-hamburger" id="sidebar-open-btn" aria-label="Open Navigation">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <!-- Perfectly Centered Logo -->
    <div class="logo-container">
      <a href="{{ routes.root_url }}">
        {%- if settings.logo != blank -%}
          {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
          {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
          {{ settings.logo | image_url: width: 500 | image_tag:
            style: 'height: 38px; width: auto;',
            class: 'header__heading-logo',
            widths: '50, 100, 150, 200, 250, 300, 400, 500',
            height: logo_height,
            width: settings.logo_width,
            alt: logo_alt
          }}
        {%- else -%}
          <span style="font-family: var(--font-primary); font-weight: 800; font-size: 24px; color: var(--color-primary);">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- [DESKTOP] Right Side Actions -->
    <div class="desktop-actions">
      {%- if section.settings.enable_language_selector -%}
        <span class="lang-selector">English</span>
      {%- endif -%}
      <button class="action-btn" id="search-open-btn-desktop" aria-label="Open Search">
        <i class="fa-solid fa-magnifying-glass"></i>
      </button>
      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="action-btn" aria-label="Account">
          <i class="fa-regular fa-circle-user"></i>
        </a>
      {%- endif -%}
      <button class="action-btn" id="cart-open-btn-desktop" aria-label="Open Cart">
        <i class="fa-solid fa-bag-shopping"></i>
        <span class="cart-badge" id="cart-badge-count">{{ cart.item_count }}</span>
      </button>
    </div>

    <!-- [MOBILE] Right Side Actions -->
    <div class="mobile-header-right">
      <button class="mobile-cart-btn" id="search-open-btn-mobile" aria-label="Open Search" style="font-size: 20px; margin-right: 4px;">
        <i class="fa-solid fa-magnifying-glass"></i>
      </button>
      <button class="mobile-cart-btn" id="cart-open-btn-mobile" aria-label="Open Cart">
        <i class="fa-solid fa-bag-shopping"></i>
        <span class="cart-badge" id="cart-badge-count-mobile">{{ cart.item_count }}</span>
      </button>
    </div>

  </div>
</div>

<!-- Global Overlay Background -->
<div class="overlay" id="global-overlay"></div>

<!-- ==================================================
     MOBILE SIDEBAR DRAWER (LEFT SIDE)
     ================================================== -->
<aside class="sidebar" id="mobile-sidebar">
  <div class="sidebar-header">
    <div class="sidebar-logo">
      {%- if settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: width: 300 }}" alt="{{ shop.name }}">
      {%- else -%}
        <span style="font-family: var(--font-primary); font-weight: 800; font-size: 20px; color: var(--color-primary);">{{ shop.name }}</span>
      {%- endif -%}
    </div>
    <button class="close-btn" id="sidebar-close-btn" aria-label="Close Navigation">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>
  
  <div class="sidebar-content">
    <nav class="sidebar-nav">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}" class="sidebar-link{% if link.active %} active{% endif %}">
          {{ link.title }} <i class="fa-solid fa-chevron-right"></i>
        </a>
      {%- endfor -%}
    </nav>

    {%- if shop.customer_accounts_enabled -%}
      <div class="sidebar-account">
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="sidebar-link">
          <span><i class="fa-regular fa-circle-user" style="margin-right: 8px; font-size: 18px; opacity: 1;"></i> My Account</span>
          <i class="fa-solid fa-chevron-right" style="opacity: 1;"></i>
        </a>
      </div>
    {%- endif -%}
  </div>

  <div class="sidebar-footer">
    <div class="sidebar-socials">
      {%- if settings.social_facebook_link != blank -%}
        <a href="{{ settings.social_facebook_link }}" class="social-icon" target="_blank" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
      {%- endif -%}
      {%- if settings.social_instagram_link != blank -%}
        <a href="{{ settings.social_instagram_link }}" class="social-icon" target="_blank" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
      {%- endif -%}
      {%- if settings.social_twitter_link != blank -%}
        <a href="{{ settings.social_twitter_link }}" class="social-icon" target="_blank" aria-label="Twitter"><i class="fa-brands fa-x-twitter"></i></a>
      {%- endif -%}
      {%- if settings.social_tiktok_link != blank -%}
        <a href="{{ settings.social_tiktok_link }}" class="social-icon" target="_blank" aria-label="TikTok"><i class="fa-brands fa-tiktok"></i></a>
      {%- endif -%}
      {%- if settings.social_pinterest_link != blank -%}
        <a href="{{ settings.social_pinterest_link }}" class="social-icon" target="_blank" aria-label="Pinterest"><i class="fa-brands fa-pinterest-p"></i></a>
      {%- endif -%}
    </div>
  </div>
</aside>

<!-- ==================================================
     PREDICTIVE SEARCH DRAWER (POPUP)
     ================================================== -->
<div class="search-drawer" id="search-drawer">
  <div class="search-container">
    <form action="{{ routes.search_url }}" method="get" role="search" class="search-input-wrapper">
      <input type="hidden" name="type" value="product">
      <i class="fa-solid fa-magnifying-glass"></i>
      <input type="text" name="q" class="search-input" id="search-bar-input" placeholder="Search our store..." autocomplete="off">
      <button type="submit" style="display:none;"></button>
      <button type="button" class="search-close-btn" id="search-close-btn" aria-label="Close Search">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </form>

    <!-- Suggestion matches container -->
    <div class="live-search-results" id="live-search-results">
      <div class="results-heading">Suggestions</div>
      <div class="search-product-grid" id="search-results-grid"></div>
    </div>
  </div>
</div>

<!-- ==================================================
     DYNAMIC CART DRAWER (AJAX INTEGRATED)
     ================================================== -->
<aside class="cart-drawer" id="cart-drawer">
  <div class="cart-header">
    <span class="cart-title">Your Cart (<span id="cart-total-qty">{{ cart.item_count }}</span>)</span>
    <button class="close-btn" id="cart-close-btn" aria-label="Close Cart">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>

  <div class="cart-content" id="cart-drawer-content">
    <!-- Empty Cart state -->
    <div class="cart-empty-state" id="cart-empty" {% if cart.item_count > 0 %}style="display: none;"{% endif %}>
      <i class="fa-solid fa-bag-shopping"></i>
      <p>Your cart is currently empty.</p>
      <button class="btn-checkout" id="btn-continue-shopping">Continue Shopping</button>
    </div>

    <!-- Populated Cart item listing -->
    <div class="cart-items-list" id="cart-items-container" {% if cart.item_count == 0 %}style="display: none;"{% endif %}>
      {%- for item in cart.items -%}
        <div class="cart-item" data-key="{{ item.key }}">
          <div class="cart-item-img">
            {%- if item.image != blank -%}
              <img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.title | escape }}">
            {%- else -%}
              <i class="fa-solid fa-shirt" style="font-size: 32px; color: var(--color-primary);"></i>
            {%- endif -%}
          </div>
          <div class="cart-item-details">
            <div>
              <div class="cart-item-title">{{ item.product.title }}</div>
              {%- unless item.product.has_only_default_variant -%}
                <div style="font-size: 12px; color: #777; margin-top: 2px;">{{ item.variant.title }}</div>
              {%- endunless -%}
              <div class="cart-item-price">{{ item.final_line_price | money }}</div>
            </div>
            <div class="cart-item-qty">
              <button class="qty-btn" data-action="decrease" data-key="{{ item.key }}" data-qty="{{ item.quantity }}"><i class="fa-solid fa-minus"></i></button>
              <span class="qty-val">{{ item.quantity }}</span>
              <button class="qty-btn" data-action="increase" data-key="{{ item.key }}" data-qty="{{ item.quantity }}"><i class="fa-solid fa-plus"></i></button>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>

  <!-- Cart Drawer Action Footer -->
  <div class="cart-footer" id="cart-footer" {% if cart.item_count > 0 %}style="display: block;"{% endif %}>
    <div class="cart-summary-row">
      <span>Subtotal</span>
      <span id="cart-subtotal-price">{{ cart.total_price | money }}</span>
    </div>
    <form action="{{ routes.cart_url }}" method="post">
      <button type="submit" name="checkout" class="btn-checkout">Proceed to Checkout</button>
    </form>
    <button class="btn-secondary" id="btn-cart-continue">Continue Shopping</button>
  </div>
</aside>

<!-- ==================================================
     JAVASCRIPT LOGIC FOR DRAWER CONTROLS, AJAX & SEARCH
     ================================================== -->
<script>
  document.addEventListener("DOMContentLoaded", () => {
    
    // Shopify Theme endpoint mappings
    const urls = {
      search: '/search/suggest.json',
      cart_change: '/cart/change.js',
      cart_get: '/cart.js'
    };

    // DOM selectors
    const overlay = document.getElementById("global-overlay");
    const mainHeader = document.getElementById("main-header");
    
    const sidebar = document.getElementById("mobile-sidebar");
    const sidebarOpenBtn = document.getElementById("sidebar-open-btn");
    const sidebarCloseBtn = document.getElementById("sidebar-close-btn");
    
    const searchDrawer = document.getElementById("search-drawer");
    const searchOpenBtnDesktop = document.getElementById("search-open-btn-desktop");
    const searchOpenBtnMobile = document.getElementById("search-open-btn-mobile");
    const searchCloseBtn = document.getElementById("search-close-btn");
    const searchInput = document.getElementById("search-bar-input");
    const searchResults = document.getElementById("live-search-results");
    const searchResultsGrid = document.getElementById("search-results-grid");
    
    const cartDrawer = document.getElementById("cart-drawer");
    const cartOpenBtnDesktop = document.getElementById("cart-open-btn-desktop");
    const cartOpenBtnMobile = document.getElementById("cart-open-btn-mobile");
    const cartCloseBtn = document.getElementById("cart-close-btn");
    const cartEmptyState = document.getElementById("cart-empty");
    const cartItemsContainer = document.getElementById("cart-items-container");
    const cartFooter = document.getElementById("cart-footer");
    const cartTotalQty = document.getElementById("cart-total-qty");
    const cartSubtotalPrice = document.getElementById("cart-subtotal-price");
    const cartBadgeCount = document.getElementById("cart-badge-count");
    const cartBadgeCountMobile = document.getElementById("cart-badge-count-mobile");
    const btnContinueShopping = document.getElementById("btn-continue-shopping");
    const btnCartContinue = document.getElementById("btn-cart-continue");

    // Drawer helpers
    function openDrawer(drawer) {
      drawer.classList.add("active");
      overlay.classList.add("active");
      document.body.style.overflow = "hidden";
    }

    function closeAllDrawers() {
      sidebar.classList.remove("active");
      cartDrawer.classList.remove("active");
      searchDrawer.classList.remove("active");
      overlay.classList.remove("active");
      document.body.style.overflow = "";
    }

    overlay.addEventListener("click", closeAllDrawers);

    // Sticky Scroll Action listener
    {%- if section.settings.sticky_header_type != 'none' -%}
      window.addEventListener("scroll", () => {
        if (window.scrollY > 100) {
          mainHeader.classList.add("is-sticky");
        } else {
          mainHeader.classList.remove("is-sticky");
        }
      });
    {%- endif -%}

    // Mobile Hamburger controls
    if (sidebarOpenBtn && sidebarCloseBtn) {
      sidebarOpenBtn.addEventListener("click", () => openDrawer(sidebar));
      sidebarCloseBtn.addEventListener("click", closeAllDrawers);
    }

    // Search Popup hooks
    function launchSearch() {
      openDrawer(searchDrawer);
      searchInput.focus();
    }

    if (searchOpenBtnDesktop) searchOpenBtnDesktop.addEventListener("click", launchSearch);
    if (searchOpenBtnMobile) searchOpenBtnMobile.addEventListener("click", launchSearch);
    if (searchCloseBtn) searchCloseBtn.addEventListener("click", closeAllDrawers);

    // Live search input handler
    let suggestDelay;
    searchInput.addEventListener("input", (e) => {
      clearTimeout(suggestDelay);
      const query = e.target.value.trim();
      
      if (query.length > 1) {
        suggestDelay = setTimeout(() => {
          fetch(`${urls.search}?q=${encodeURIComponent(query)}&resources[type]=product&resources[limit]=4`)
            .then(res => res.json())
            .then(data => {
              const products = data.resources.results.products || [];
              renderSearchResults(products);
              searchResults.classList.add("active");
            })
            .catch(err => console.error("Predictive search request failed:", err));
        }, 300);
      } else {
        searchResults.classList.remove("active");
      }
    });

    function renderSearchResults(products) {
      searchResultsGrid.innerHTML = "";
      if (products.length === 0) {
        searchResultsGrid.innerHTML = `<div style="grid-column: 1/-1; text-align: center; color: #999; font-size: 14px; padding: 20px 0;">No products found</div>`;
        return;
      }

      products.forEach(p => {
        const item = document.createElement("a");
        item.href = p.url;
        item.className = "search-product-card";
        item.innerHTML = `
          <div class="search-prod-img">
            ${p.image ? `<img src="${p.image}" alt="${p.title}">` : `<i class="fa-solid fa-shirt"></i>`}
          </div>
          <div class="search-prod-details">
            <span class="search-prod-title">${p.title}</span>
            <span class="search-prod-price">${p.price}</span>
          </div>
        `;
        searchResultsGrid.appendChild(item);
      });
    }

    // AJAX Cart functionality
    if (cartOpenBtnDesktop) cartOpenBtnDesktop.addEventListener("click", () => openDrawer(cartDrawer));
    if (cartOpenBtnMobile) cartOpenBtnMobile.addEventListener("click", () => openDrawer(cartDrawer));
    if (cartCloseBtn) cartCloseBtn.addEventListener("click", closeAllDrawers);
    if (btnContinueShopping) btnContinueShopping.addEventListener("click", closeAllDrawers);
    if (btnCartContinue) btnCartContinue.addEventListener("click", closeAllDrawers);

    // Refresh layout view with Shopify Cart API
    function fetchAndRenderCart() {
      fetch(urls.cart_get)
        .then(res => res.json())
        .then(cartData => {
          // Sync state values
          cartBadgeCount.textContent = cartData.item_count;
          cartBadgeCountMobile.textContent = cartData.item_count;
          cartTotalQty.textContent = cartData.item_count;

          if (cartData.item_count === 0) {
            cartEmptyState.style.display = "flex";
            cartItemsContainer.style.display = "none";
            cartFooter.style.display = "none";
          } else {
            cartEmptyState.style.display = "none";
            cartItemsContainer.style.display = "flex";
            cartFooter.style.display = "block";
            
            const totalMoney = Shopify.formatMoney 
              ? Shopify.formatMoney(cartData.total_price) 
              : `$${(cartData.total_price / 100).toFixed(2)}`;
            cartSubtotalPrice.textContent = totalMoney;

            renderCartItems(cartData.items);
          }
        })
        .catch(err => console.error("Could not fetch cart items:", err));
    }

    function renderCartItems(items) {
      cartItemsContainer.innerHTML = "";
      items.forEach(item => {
        const itemLinePrice = Shopify.formatMoney 
          ? Shopify.formatMoney(item.final_line_price) 
          : `$${(item.final_line_price / 100).toFixed(2)}`;

        const cartItemEl = document.createElement("div");
        cartItemEl.className = "cart-item";
        cartItemEl.setAttribute("data-key", item.key);
        cartItemEl.innerHTML = `
          <div class="cart-item-img">
            ${item.image ? `<img src="${item.image}" alt="${item.title}">` : `<i class="fa-solid fa-shirt"></i>`}
          </div>
          <div class="cart-item-details">
            <div>
              <div class="cart-item-title">${item.product_title}</div>
              ${item.variant_options && item.variant_options.length > 0 && item.variant_title ? `<div style="font-size: 12px; color: #777; margin-top: 2px;">${item.variant_title}</div>` : ''}
              <div class="cart-item-price">${itemLinePrice}</div>
            </div>
            <div class="cart-item-qty">
              <button class="qty-btn" data-action="decrease" data-key="${item.key}" data-qty="${item.quantity}"><i class="fa-solid fa-minus"></i></button>
              <span class="qty-val">${item.quantity}</span>
              <button class="qty-btn" data-action="increase" data-key="${item.key}" data-qty="${item.quantity}"><i class="fa-solid fa-plus"></i></button>
            </div>
          </div>
        `;
        cartItemsContainer.appendChild(cartItemEl);
      });

      // Bind dynamic quantity actions
      document.querySelectorAll(".cart-item-qty .qty-btn").forEach(btn => {
        btn.addEventListener("click", (e) => {
          const key = e.currentTarget.getAttribute("data-key");
          const action = e.currentTarget.getAttribute("data-action");
          const curQty = parseInt(e.currentTarget.getAttribute("data-qty"));
          
          let nextQty = action === "increase" ? curQty + 1 : curQty - 1;
          
          updateItemQuantity(key, nextQty);
        });
      });
    }

    function updateItemQuantity(key, qty) {
      fetch(urls.cart_change, {
        method: "POST",
        headers: { "Content-Type": "application/json", "Accept": "application/json" },
        body: JSON.stringify({ id: key, quantity: qty })
      })
      .then(res => res.json())
      .then(() => {
        fetchAndRenderCart();
      })
      .catch(err => console.error("Error setting item quantity:", err));
    }

    // Load initial cart representation
    fetchAndRenderCart();
  });
</script>

{% schema %}
{
  "name": "Custom Capsule Header",
  "class": "section-header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Header Menu"
    },
    {
      "type": "select",
      "id": "sticky_header_type",
      "options": [
        {
          "value": "none",
          "label": "Disable Sticky Scroll"
        },
        {
          "value": "always",
          "label": "Sticky Header Enabled"
        }
      ],
      "default": "always",
      "label": "Sticky Behavior"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": true,
      "label": "Show Language selector ('English')"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Spacing",
      "default": 0
    }
  ]
}
{% endschema %}
