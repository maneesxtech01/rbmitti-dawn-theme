  ],
  "presets": [
    {
      "name": "Custom Our Story",
      "blocks": [
        {
          "type": "subheading",
          "settings": {
            "text": "FOUNDER'S STORY",
            "color": "#f63208"
          }
        },
        {
          "type": "heading",
          "settings": {
            "text": "FROM INDUSTRY INSIDERS TO NATURAL REBELS",
