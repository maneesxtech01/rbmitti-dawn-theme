{%- style -%}
  #custom-our-story-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    {%- if section.settings.show_border_bottom -%}
      border-bottom: 1px solid {{ section.settings.border_bottom_color }};
    {%- endif -%}
  }

  @media screen and (min-width: 768px) {
    #custom-our-story-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #custom-our-story-{{ section.id }} .story__container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 24px;
    font-family: var(--font-body-family), "Poppins", sans-serif;
  }

  #custom-our-story-{{ section.id }} .story__wrapper {
    display: flex;
    flex-direction: column;
    gap: 40px;
    align-items: center;
  }

  @media screen and (min-width: 992px) {
    #custom-our-story-{{ section.id }} .story__wrapper {
      flex-direction: {% if section.settings.layout_desktop == 'image_left' %}row{% else %}row-reverse{% endif %};
      gap: 60px;
    }
  }

  #custom-our-story-{{ section.id }} .story__image-column {
    width: 100%;
    flex: 1;
  }

  @media screen and (max-width: 991px) {
    #custom-our-story-{{ section.id }} .story__image-column {
      order: 1;
    }
    #custom-our-story-{{ section.id }} .story__content-column {
      order: 2;
    }
  }

  #custom-our-story-{{ section.id }} .story__content-column {
    width: 100%;
    flex: 1.1;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
  }

  #custom-our-story-{{ section.id }} .story__img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    border-radius: {{ section.settings.image_border_radius }}px;
    {%- case section.settings.image_aspect_ratio -%}
      {%- when 'square' -%}
        aspect-ratio: 1 / 1;
      {%- when 'portrait' -%}
        aspect-ratio: 4 / 5;
      {%- when 'landscape' -%}
        aspect-ratio: 16 / 9;
      {%- else -%}
        aspect-ratio: auto;
    {%- endcase -%}
  }

  /* Block Specific Scoped Styles */
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'subheading' -%}
        #custom-our-story-{{ section.id }} .block-{{ block.id }} {
          color: {{ block.settings.color }};
          font-size: 14px;
          font-weight: 700;
          line-height: 1.5;
          text-transform: uppercase;
          letter-spacing: 0.05em;
          display: inline-block;
        }
      {%- when 'heading' -%}
        #custom-our-story-{{ section.id }} .block-{{ block.id }} {
          color: {{ block.settings.color }};
          font-family: var(--font-heading-family), inherit;
          font-size: clamp(28px, 4vw, 42px);
          font-weight: 800;
          line-height: 1.1;
          margin: 0;
          text-transform: uppercase;
        }
      {%- when 'quote_box' -%}
        #custom-our-story-{{ section.id }} .block-{{ block.id }} {
          background-color: {{ block.settings.bg_color }};
          border: 1px solid {{ block.settings.border_color }};
          color: {{ block.settings.text_color }};
          padding: 16px 20px;
          border-radius: 4px;
          font-weight: 600;
          font-size: 15px;
          line-height: 1.4;
          width: 100%;
          margin: 8px 0;
          box-sizing: border-box;
        }
      {%- when 'text' -%}
        #custom-our-story-{{ section.id }} .block-{{ block.id }} {
          color: {{ block.settings.color }};
          font-size: 15px;
          line-height: 1.6;
          margin: 0;
        }
        #custom-our-story-{{ section.id }} .block-{{ block.id }} p {
          margin: 0 0 16px 0;
        }
        #custom-our-story-{{ section.id }} .block-{{ block.id }} p:last-child {
          margin-bottom: 0;
        }
      {%- when 'bullet_point' -%}
        #custom-our-story-{{ section.id }} .block-{{ block.id }} {
          display: flex;
          align-items: flex-start;
          gap: 10px;
          margin: 4px 0;
        }
        #custom-our-story-{{ section.id }} .block-{{ block.id }} .story__bullet-icon {
          color: {{ block.settings.icon_color }};
          font-size: 18px;
          font-weight: 700;
          line-height: 1;
        }
        #custom-our-story-{{ section.id }} .block-{{ block.id }} .story__bullet-text {
          color: {{ block.settings.text_color }};
          font-size: 15px;
          line-height: 1.4;
        }
      {%- when 'html_widget' -%}
        #custom-our-story-{{ section.id }} .block-{{ block.id }} {
          width: 100%;
        }
      {%- when 'button' -%}
        #custom-our-story-{{ section.id }} .block-{{ block.id }} {
          display: inline-block;
          padding: 14px 28px;
          font-size: 16px;
          font-weight: 700;
          line-height: 1.5;
          color: {{ block.settings.button_text_color }};
          text-decoration: none;
          border-radius: 12px;
          border: 1.5px solid {{ block.settings.button_border_color }};
          background-color: {{ block.settings.button_bg_color }};
          box-shadow: 0px 4px 0px 0px {{ block.settings.button_shadow_color }};
          transition: transform 0.15s ease, box-shadow 0.15s ease;
          margin-top: 8px;
          cursor: pointer;
          position: relative;
          top: 0;
        }
        #custom-our-story-{{ section.id }} .block-{{ block.id }}:hover {
          transform: translateY(2px);
          box-shadow: 0px 2px 0px 0px {{ block.settings.button_shadow_color }};
        }
        #custom-our-story-{{ section.id }} .block-{{ block.id }}:active {
          transform: translateY(4px);
          box-shadow: 0px 0px 0px 0px {{ block.settings.button_shadow_color }};
        }
    {%- endcase -%}
  {%- endfor -%}
{%- endstyle -%}

<section id="custom-our-story-{{ section.id }}" class="story-section">
  <div class="story__container">
    <div class="story__wrapper">
      
      <!-- Image Column -->
      <div class="story__image-column">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 800 | image_tag: 
            class: 'story__img', 
            loading: 'lazy', 
            alt: section.settings.image.alt | default: 'Our Story Image' 
          }}
        {%- else -%}
          <img 
            src="https://images.unsplash.com/photo-1608248597279-f99d160bfcbc?q=80&w=800&auto=format&fit=crop" 
            class="story__img" 
            loading="lazy" 
            alt="Our Story Product Showcase Placeholder"
            width="600"
            height="600"
          >
        {%- endif -%}
      </div>

      <!-- Content Column -->
      <div class="story__content-column">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            
            {%- when 'subheading' -%}
              <span class="story__subheading block-{{ block.id }}" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </span>
            
            {%- when 'heading' -%}
              <h2 class="story__heading block-{{ block.id }}" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </h2>
            
            {%- when 'quote_box' -%}
              <div class="story__quote-box block-{{ block.id }}" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>
            
            {%- when 'text' -%}
              <div class="story__text block-{{ block.id }}" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>
            
            {%- when 'bullet_point' -%}
              <div class="story__bullet-point block-{{ block.id }}" {{ block.shopify_attributes }}>
                <span class="story__bullet-icon">✓</span>
                <span class="story__bullet-text">{{ block.settings.text }}</span>
              </div>
            
            {%- when 'html_widget' -%}
              <div class="story__html-widget block-{{ block.id }}" {{ block.shopify_attributes }}>
                {{ block.settings.html_code }}
              </div>
            
            {%- when 'button' -%}
              <a href="{{ block.settings.button_link | default: '#' }}" class="story__button block-{{ block.id }}" {{ block.shopify_attributes }}>
                {{ block.settings.button_text }}
              </a>

          {%- endcase -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Our Story",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "select",
      "id": "layout_desktop",
      "label": "Desktop Image Alignment",
      "options": [
        {
          "value": "image_left",
          "label": "Image Left"
        },
        {
          "value": "image_right",
          "label": "Image Right"
        }
      ],
      "default": "image_left"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Max Container Width",
      "default": 1200
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "show_border_bottom",
      "label": "Show Border Bottom",
      "default": false
    },
    {
      "type": "color",
      "id": "border_bottom_color",
      "label": "Border Bottom Color",
      "default": "#2c2609"
    },
    {
      "type": "header",
      "content": "Story Image settings"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Story Image"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image Aspect Ratio",
      "options": [
        {
          "value": "auto",
          "label": "Auto / Original"
        },
        {
          "value": "square",
          "label": "Square (1:1)"
        },
        {
          "value": "portrait",
          "label": "Portrait (4:5)"
        },
        {
          "value": "landscape",
          "label": "Landscape (16:9)"
        }
      ],
      "default": "square"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Image Border Radius",
      "default": 8
    },
    {
      "type": "header",
      "content": "Spacing Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "subheading",
      "name": "Subheading / Label",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Subheading Text",
          "default": "FOUNDER'S STORY"
        },
        {
          "type": "color",
          "id": "color",
          "label": "Text Color",
          "default": "#f63208"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Heading Text",
          "default": "FROM INDUSTRY INSIDERS TO NATURAL REBELS"
        },
        {
          "type": "color",
          "id": "color",
          "label": "Text Color",
          "default": "#1d211e"
        }
      ]
    },
    {
      "type": "quote_box",
      "name": "Highlight Quote Box",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Quote Text",
