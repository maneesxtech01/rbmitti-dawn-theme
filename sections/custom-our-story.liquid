        },
        {
          "type": "color",
          "id": "border_color",
          "label": "Border Color",
          "default": "#2c2609"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#2c2609"
        }
      ]
    },
    {
      "type": "text",
      "name": "Paragraph Text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Paragraph content",
