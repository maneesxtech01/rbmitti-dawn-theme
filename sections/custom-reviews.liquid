<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  (function () {
    function initLpReviews() {
      document.querySelectorAll(".lp-rev-{{ section.id }}").forEach(function (sec) {
        if (sec.dataset.init === "true") return;
        sec.dataset.init = "true";

        const swiperContainer = sec.querySelector(".reviews-swiper-{{ section.id }}");
        const prevBtn = sec.querySelector(".lp-nav-prev");
        const nextBtn = sec.querySelector(".lp-nav-next");

        if (!swiperContainer) return;

        const swiper = new Swiper(swiperContainer, {
          slidesPerView: "auto",
          spaceBetween: 24,
          centeredSlides: false,
          loop: false,
          grabCursor: true,
          watchSlidesProgress: true,
          breakpoints: {
            320: {
              spaceBetween: 16
            },
            600: {
              spaceBetween: 20
            },
            900: {
              spaceBetween: 24
            }
          }
        });

        if (prevBtn && nextBtn) {
          prevBtn.addEventListener("click", function () {
            if (swiper.isBeginning) {
              swiper.slideTo(swiper.slides.length - 1);
            } else {
              swiper.slidePrev();
            }
          });

          nextBtn.addEventListener("click", function () {
            if (swiper.isEnd) {
              swiper.slideTo(0);
            } else {
              swiper.slideNext();
            }
          });
        }
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initLpReviews);
    } else {
      initLpReviews();
    }

    document.addEventListener("shopify:section:load", function (e) {
      if (e.target.classList.contains("section") && e.target.querySelector(".lp-rev-{{ section.id }}")) {
        initLpReviews();
      }
    });

    window.addEventListener("load", initLpReviews);
    setTimeout(initLpReviews, 500);
    setTimeout(initLpReviews, 1200);
  })();
</script>

